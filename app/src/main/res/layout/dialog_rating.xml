<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >
    <TextView
        android:id="@+id/item_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="hoge hoge hoge hoge hoge hoge hoge hoge hoge hoge hoge hoge"
        android:textSize="18sp"
        android:background="@drawable/bordered_bg"
        android:padding="8dp"
        />

    <TextView
        android:id="@+id/rating_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/item_name"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="@dimen/setting_spacing"
        android:text="@string/rating_label"
        android:layout_gravity="center_vertical"
        android:minWidth="@dimen/min_label_width"
        android:textStyle="bold"
        android:textSize="16sp"
        />
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/rating_selector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/rating_label"
        app:layout_constraintStart_toStartOf="parent"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        >
        <com.google.android.material.button.MaterialButton
            android:id="@+id/tg_rating_dreadful"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_toggle_button_width"
            app:icon="@drawable/ic_dreadful"
            app:iconPadding="0dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/tg_rating_bad"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_toggle_button_width"
            app:icon="@drawable/ic_bad"
            app:iconPadding="0dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/tg_rating_normal"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_toggle_button_width"
            app:icon="@drawable/ic_normal"
            app:iconPadding="0dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/tg_rating_good"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_toggle_button_width"
            app:icon="@drawable/ic_good"
            app:iconPadding="0dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/tg_rating_excellent"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_toggle_button_width"
            app:icon="@drawable/ic_excellent"
            app:iconPadding="0dp"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <TextView
        android:id="@+id/mark_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/rating_selector"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="@dimen/setting_spacing"
        android:text="@string/mark_label"
        android:layout_gravity="center_vertical"
        android:minWidth="@dimen/min_label_width"
        android:textStyle="bold"
        android:textSize="16sp"
        />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/mark_selector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/mark_label"
        app:layout_constraintStart_toStartOf="parent"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        >
        <Button
            android:id="@+id/tg_mark_star"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_toggle_button_width"
            app:icon="@drawable/ic_star"
            app:iconPadding="0dp"/>
        <Button
            android:id="@+id/tg_mark_flag"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_toggle_button_width"
            app:icon="@drawable/ic_flag"
            app:iconPadding="0dp"/>
        <Button
            android:id="@+id/tg_mark_heart"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_toggle_button_width"
            app:icon="@drawable/ic_heart"
            app:iconPadding="0dp"
            />
    </com.google.android.material.button.MaterialButtonToggleGroup>


    <TextView
        android:id="@+id/category_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/rating_selector"
        app:layout_constraintStart_toEndOf="@+id/mark_selector"
        android:layout_marginTop="@dimen/setting_spacing"
        android:text="@string/category_label"
        android:layout_gravity="center_vertical"
        android:minWidth="@dimen/min_label_width"
        app:singleSelection="true"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginStart="16dp"
        />
    <Button
        android:id="@+id/category_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/category_label"
        app:layout_constraintStart_toStartOf="@+id/category_label"
        android:layout_gravity="center"
        android:minEms="10"
        style="?attr/materialButtonOutlinedStyle"
        android:textAllCaps="false"
        android:textAlignment="center"
        android:textColor="?attr/colorPrimary"
        tools:text="All"
        android:layout_marginStart="12dp"
        />

    <TextView
        android:id="@+id/sync_selection_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/category_button"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="@dimen/setting_spacing"
        android:text="@string/sync_selection_label"
        android:layout_gravity="center_vertical"
        android:minWidth="@dimen/min_label_width"
        app:singleSelection="true"
        android:textStyle="bold"
        android:textSize="16sp"
        />
    <LinearLayout
        android:id="@+id/sync_selection_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/sync_selection_label"
        app:layout_constraintStart_toStartOf="parent"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        >

        <Button
            android:id="@+id/sync_up_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_up"
            app:iconSize="24dp"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:tint="?attr/colorPrimary"
            style="?attr/materialButtonOutlinedStyle"/>
        <Space
            android:layout_width="5dp"
            android:layout_height="0dp"/>
        <Button
            android:id="@+id/sync_down_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_down"
            app:iconSize="24dp"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:tint="?attr/colorPrimary"
            style="?attr/materialButtonOutlinedStyle"/>
    </LinearLayout>

    <TextView
        android:id="@+id/offline_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/category_button"
        app:layout_constraintStart_toStartOf="@+id/category_label"
        android:layout_marginTop="@dimen/setting_spacing"
        android:text="@string/offline_label"
        app:singleSelection="true"
        android:textStyle="bold"
        android:textSize="16sp"
        />
    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/offline_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@+id/sync_selection_buttons"
        app:layout_constraintBottom_toBottomOf="@+id/sync_selection_buttons"
        app:layout_constraintStart_toStartOf="@+id/category_button"
        />

    <io.github.toyota32k.viewex.library.CircularProgressBar
        android:id="@+id/upload_progress_ring"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:layout_constraintStart_toEndOf="@+id/offline_switch"
        app:layout_constraintTop_toTopOf="@+id/offline_switch"
        app:layout_constraintBottom_toBottomOf="@+id/offline_switch"
        android:layout_marginStart="28dp"
        app:ringBaseColor="?attr/colorSurfaceBright"
        app:progressColor="?attr/colorTertiary"
        app:insideRingColor="?attr/colorSurface"
        app:textColor="?attr/colorOnSurface"
        />

    <FrameLayout
        android:id="@+id/busy_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/item_name"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_gravity="center"
        android:background="#6000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        >
        <ProgressBar
            tools:visibility="visible"
            style="?android:attr/progressBarStyleLarge"
            android:id="@+id/exp_progressRing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|center_vertical"
            android:visibility="visible"
            android:background="@null"
            />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
